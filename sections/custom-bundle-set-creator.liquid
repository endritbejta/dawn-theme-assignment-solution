                    d="M12.0001 2.75C10.7574 2.75 9.75006 3.75736 9.75006 5V5.25447C10.1676 5.24999 10.6183 5.25 11.1053 5.25H12.8948C13.3819 5.25 13.8326 5.24999 14.2501 5.25447V5C14.2501 3.75736 13.2427 2.75 12.0001 2.75ZM15.7501 5.30694V5C15.7501 2.92893 14.0711 1.25 12.0001 1.25C9.929 1.25 8.25006 2.92893 8.25006 5V5.30694C8.11506 5.31679 7.98479 5.32834 7.85904 5.34189C6.98068 5.43657 6.24614 5.63489 5.59385 6.08197C5.3695 6.23574 5.15877 6.40849 4.96399 6.59833C4.39766 7.15027 4.05914 7.83166 3.79405 8.67439C3.53667 9.49258 3.32867 10.5327 3.06729 11.8396L3.04822 11.935C2.67158 13.8181 2.37478 15.302 2.28954 16.484C2.20244 17.6916 2.32415 18.7075 2.89619 19.588C3.08705 19.8817 3.30982 20.1534 3.56044 20.3982C4.31157 21.1318 5.28392 21.4504 6.48518 21.6018C7.66087 21.75 9.17418 21.75 11.0946 21.75H12.9055C14.826 21.75 16.3393 21.75 17.5149 21.6018C18.7162 21.4504 19.6886 21.1318 20.4397 20.3982C20.6903 20.1534 20.9131 19.8817 21.1039 19.588C21.676 18.7075 21.7977 17.6916 21.7106 16.484C21.6254 15.3021 21.3286 13.8182 20.9519 11.9351L20.9328 11.8396C20.6715 10.5327 20.4635 9.49259 20.2061 8.67439C19.941 7.83166 19.6025 7.15027 19.0361 6.59833C18.8414 6.40849 18.6306 6.23574 18.4063 6.08197C17.754 5.63489 17.0194 5.43657 16.1411 5.34189C16.0153 5.32834 15.8851 5.31679 15.7501 5.30694ZM8.01978 6.83326C7.27307 6.91374 6.81176 7.06572 6.44188 7.31924C6.28838 7.42445 6.1442 7.54265 6.01093 7.67254C5.68979 7.98552 5.45028 8.40807 5.22492 9.12449C4.99463 9.85661 4.80147 10.8172 4.52967 12.1762C4.14013 14.1239 3.8633 15.5153 3.78565 16.5919C3.70906 17.6538 3.83838 18.2849 4.15401 18.7707C4.2846 18.9717 4.43702 19.1576 4.60849 19.3251C5.02293 19.7298 5.61646 19.9804 6.67278 20.1136C7.74368 20.2486 9.1623 20.25 11.1486 20.25H12.8515C14.8378 20.25 16.2564 20.2486 17.3273 20.1136C18.3837 19.9804 18.9772 19.7298 19.3916 19.3251C19.5631 19.1576 19.7155 18.9717 19.8461 18.7707C20.1617 18.2849 20.2911 17.6538 20.2145 16.5919C20.1368 15.5153 19.86 14.1239 19.4705 12.1762C19.1987 10.8173 19.0055 9.85661 18.7752 9.12449C18.5498 8.40807 18.3103 7.98552 17.9892 7.67254C17.8559 7.54265 17.7118 7.42445 17.5582 7.31924C17.1884 7.06572 16.7271 6.91374 15.9803 6.83326C15.2173 6.75101 14.2374 6.75 12.8515 6.75H11.1486C9.76271 6.75 8.78285 6.75101 8.01978 6.83326Z"
                    fill="#000"></path>
                </g>
              </svg>

              <span class="bundle-checkout-button__label">Add bundle to Cart</span>
            </button>
          </div>
        </div>
    </div>
  </div>
</div>
<script>
document.addEventListener("DOMContentLoaded", () => {
  /* ===========================================================================
   * CUSTOM BUNDLE SET CREATOR
   *
   * Self-contained section script that lets customers build a product bundle,
   * preview it in a sidebar cart, then add the entire bundle to the Shopify
   * cart in one click via the AJAX Cart API.
   *
   * Scoped to a single section instance — safe for multiple sections per page.
   * ========================================================================= */

  const root = document.getElementById("bundle-set-creator-{{ section.id }}");
  if (!root) return;

  const sectionId = "{{ section.id }}";
  const moneyFormat = {{ shop.money_format | json }};

  // Tiered discounts applied based on total item count in the bundle.
  // Adjust thresholds and percentages here as needed.
  const DISCOUNT_TIERS = [
    { qty: 3, percent: 10 },
    { qty: 5, percent: 15 }
  ];

  const ROOT_URL = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || "/";

  /* ---------------------------------------------------------------------------
   * BUNDLE STATE + PERSISTENCE
   *
   * Local state for the bundle builder UI. Keyed by "productId:variantId"
   * so the same product in different variants occupies separate slots.
   * Reset to {} after a successful add-to-cart.
   *
   * Persisted to localStorage so the customer's in-progress bundle survives
   * page navigations (e.g. browsing a product page and coming back).
   * The storage key includes the section ID to avoid collisions when multiple
   * bundle creators exist across different pages.
   * ------------------------------------------------------------------------- */
  const BUNDLE_STORAGE_KEY = "bundle_state_" + sectionId;
  let bundle = {};

  /** Saves the current bundle state to localStorage. */
  function saveBundleState() {
    try {
      localStorage.setItem(BUNDLE_STORAGE_KEY, JSON.stringify(bundle));
    } catch (e) {
      // localStorage may be full or disabled — fail silently.
    }
  }

  /**
   * Loads a previously saved bundle state from localStorage.
   * Returns the parsed object, or an empty object if nothing is stored
   * or the data is corrupted.
   */
  function loadBundleState() {
    try {
      return JSON.parse(localStorage.getItem(BUNDLE_STORAGE_KEY)) || {};
    } catch (e) {
      return {};
    }
  }

  /** Clears the persisted bundle state after a successful add-to-cart. */
  function clearBundleState() {
    try {
      localStorage.removeItem(BUNDLE_STORAGE_KEY);
    } catch (e) {
      // Fail silently.
    }
  }

  // Restore any previously saved bundle on page load.
  bundle = loadBundleState();

  /* ---------------------------------------------------------------------------
   * MONEY FORMATTING
   *
   * Shopify's Liquid engine parses double-curly-brace sequences even inside
   * <script> tags and comments, so the placeholder tokens are assembled via
   * concatenation at runtime to avoid Liquid evaluation.
   * ------------------------------------------------------------------------- */
  const OB = "{";
  const CB = "}";
  const MONEY_TOKENS = {
    amount:                                OB + OB + "amount" + CB + CB,
    amountNoDecimals:                      OB + OB + "amount_no_decimals" + CB + CB,
    amountWithCommaSeparator:              OB + OB + "amount_with_comma_separator" + CB + CB,
    amountWithApostropheSeparator:         OB + OB + "amount_with_apostrophe_separator" + CB + CB,
    amountNoDecimalsWithCommaSeparator:    OB + OB + "amount_no_decimals_with_comma_separator" + CB + CB,
    amountNoDecimalsWithSpaceSeparator:    OB + OB + "amount_no_decimals_with_space_separator" + CB + CB,
  };

  /**
   * Converts a price in cents to a formatted currency string using the
   * shop's configured money_format. Handles all six Shopify placeholder
   * variants and negative values.
   */
  function formatMoney(cents) {
    // Guard against invalid input — defaults to 0 if cents is not a valid number.
    if (typeof cents !== "number" || isNaN(cents)) cents = 0;

    const isNegative = cents < 0;
    const absCents = Math.abs(cents);
    const dollars = (absCents / 100).toFixed(2);
    const [whole, decimal] = dollars.split(".");

    const groupDigits = (str, sep) => str.replace(/\B(?=(\d{3})+(?!\d))/g, sep);

    const amount                             = groupDigits(whole, ",") + "." + decimal;
    const amountWithCommaSeparator           = groupDigits(whole, ".") + "," + decimal;
    const amountWithApostropheSeparator      = groupDigits(whole, "'") + "." + decimal;
    const amountNoDecimals                   = groupDigits(whole, ",");
    const amountNoDecimalsWithCommaSeparator = groupDigits(whole, ".");
    const amountNoDecimalsWithSpaceSeparator = groupDigits(whole, " ");

    const format = moneyFormat || ("$" + OB + OB + "amount" + CB + CB);

    // Replace longest tokens first to avoid partial matches.
    let result = format;
    result = result.split(MONEY_TOKENS.amountNoDecimalsWithCommaSeparator).join(amountNoDecimalsWithCommaSeparator);
    result = result.split(MONEY_TOKENS.amountNoDecimalsWithSpaceSeparator).join(amountNoDecimalsWithSpaceSeparator);
    result = result.split(MONEY_TOKENS.amountWithCommaSeparator).join(amountWithCommaSeparator);
    result = result.split(MONEY_TOKENS.amountWithApostropheSeparator).join(amountWithApostropheSeparator);
    result = result.split(MONEY_TOKENS.amountNoDecimals).join(amountNoDecimals);
    result = result.split(MONEY_TOKENS.amount).join(amount);

    return isNegative ? "-" + result : result;
  }

  /* ---------------------------------------------------------------------------
   * DISCOUNT TIER HELPERS
   * ------------------------------------------------------------------------- */

  /** Returns the highest tier the customer qualifies for, or null. */
  function getActiveTier(totalQty) {
    let active = null;
    for (let i = 0; i < DISCOUNT_TIERS.length; i++) {
      if (totalQty >= DISCOUNT_TIERS[i].qty) active = DISCOUNT_TIERS[i];
    }
    return active;
  }

  /** Returns the next tier the customer hasn't reached yet, or null. */
  function getNextTier(totalQty) {
    for (let i = 0; i < DISCOUNT_TIERS.length; i++) {
      if (totalQty < DISCOUNT_TIERS[i].qty) return DISCOUNT_TIERS[i];
    }
    return null;
  }

  /* ---------------------------------------------------------------------------
   * ERROR MESSAGING
   * ------------------------------------------------------------------------- */
  function showError(message) {
    const el = document.getElementById("bundle-error-" + sectionId);
    if (!el) return;
    if (!message) {
      el.textContent = "";
      el.classList.remove("visible");
      return;
    }
    el.textContent = message;
    el.classList.add("visible");
  }

  /* ---------------------------------------------------------------------------
   * VARIANT DROPDOWNS
   *
   * Custom dropdown UI backed by a hidden native <select> for form semantics.
   * Selecting a variant resets the quantity input to 1 since stock limits
   * may differ between variants.
   * ------------------------------------------------------------------------- */
  root.querySelectorAll(".bundle__dropdown").forEach((dropdown) => {
    const toggle = dropdown.querySelector(".bundle-dropdown-toggle");
    const toggleText = dropdown.querySelector(".bundle-dropdown-toggle span");
    const optionsList = dropdown.querySelector(".bundle-dropdown-options");
    const nativeSelect = dropdown.querySelector("select");
    if (!toggle || !optionsList || !nativeSelect) return;

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      optionsList.hidden = expanded;
    });

    dropdown.querySelectorAll(".bundle-option").forEach((option) => {
      option.addEventListener("click", () => {
        if (option.disabled) return;

        nativeSelect.value = option.dataset.variantId;
        toggleText.textContent = option.dataset.variantTitle;
        optionsList.hidden = true;
        toggle.setAttribute("aria-expanded", "false");

        const card = dropdown.closest(".bundle-product");

        // Swap the card image to the selected variant's image with a loader.
        if (card && option.dataset.imageLarge) {
          const media = card.querySelector(".bundle-product__media");
          const cardImg = card.querySelector(".bundle-product__image");
          if (cardImg && media) {
            media.classList.add("is-loading");
            const newImg = new Image();
            newImg.onload = () => media.classList.remove("is-loading");
            newImg.onerror = () => media.classList.remove("is-loading");
            newImg.src = option.dataset.imageLarge;
            cardImg.src = option.dataset.imageLarge;
          }
        }

        // Update max stock and reset quantity for the newly selected variant.
        const qtyInput = card ? card.querySelector(".bundle-quantity") : null;
        if (qtyInput) {
          const inventory = parseInt(option.dataset.inventory, 10);
          qtyInput.max = isNaN(inventory) || inventory <= 0 ? "" : inventory;
          qtyInput.value = 1;
        }
      });
    });
  });

  // Close all dropdowns when clicking outside.
  document.addEventListener("click", (event) => {
    root.querySelectorAll(".bundle__dropdown").forEach((dropdown) => {
      if (dropdown.contains(event.target)) return;
      const optionsList = dropdown.querySelector(".bundle-dropdown-options");
      const toggle = dropdown.querySelector(".bundle-dropdown-toggle");
      if (optionsList) optionsList.hidden = true;
      if (toggle) toggle.setAttribute("aria-expanded", "false");
    });
  });

  /* ---------------------------------------------------------------------------
   * QUANTITY STEPPERS (product cards)
   * ------------------------------------------------------------------------- */
  root.querySelectorAll(".bundle-product").forEach((product) => {
    const input = product.querySelector(".bundle-quantity");
    if (!input) return;

    product.querySelectorAll(".quantity-btn").forEach((button) => {
      button.addEventListener("click", () => {
        let value = Number(input.value) || 1;
        const max = Number(input.max) || Infinity;

        if (button.dataset.action === "increase" && value < max) value++;
        if (button.dataset.action === "decrease" && value > 1) value--;

        input.value = value;
      });
    });

    input.addEventListener("change", () => {
      let value = Number(input.value);
      const max = Number(input.max) || Infinity;
      if (!value || value < 1) value = 1;
      if (value > max) value = max;
      input.value = value;
    });
  });

  /* ---------------------------------------------------------------------------
   * CATEGORY FILTERS
   *
   * Filters product cards by tag. Tags are stored on each card element as a
   * comma-separated data attribute and matched against the filter button's
   * data-filter value.
   * ------------------------------------------------------------------------- */
  const filterButtons = root.querySelectorAll(".product-filters button");
  const productCards = root.querySelectorAll(".bundle__product-list .bundle-product");
  const noResultsEl = root.querySelector(".bundle-no-results");

  filterButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterButtons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      const filter = btn.dataset.filter;
      let visibleCount = 0;

      productCards.forEach((card) => {
        const tags = (card.dataset.tags || "").split(",");
        const matches = filter === "all" || tags.includes(filter);
        card.hidden = !matches;
        if (matches) visibleCount++;
      });

      if (noResultsEl) noResultsEl.hidden = visibleCount !== 0;
    });
  });

  /* ---------------------------------------------------------------------------
   * ADD TO BUNDLE
   *
   * Reads the selected variant and quantity from a product card and adds it
   * to the local bundle state. If the same product+variant already exists,
   * the quantity is incremented rather than duplicated.
   * ------------------------------------------------------------------------- */
  const REMOVE_ICON_SVG = `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14.28 2C15.14 2 15.9 2.55 16.18 3.37L16.72 5H20a1 1 0 110 2h-.003l-.867 12.214C19.02 20.784 17.71 22 16.14 22H7.86c-1.574 0-2.88-1.216-2.993-2.786L4.003 7H4a1 1 0 110-2h3.28l.543-1.63A1.886 1.886 0 019.72 2h4.56zM18 7H6.003l.86 12.071A.999.999 0 007.863 20h8.275a.999.999 0 00.998-.929L18 7zm-8 3a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm4 0a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm.28-6H9.72l-.334 1h5.228l-.334-1z" fill="currentColor"/></svg>`;

  root.querySelectorAll(".bundle-add-button").forEach((button) => {
    button.addEventListener("click", () => {
      const card = button.closest(".bundle-product");
      if (!card) return;

      const productId = card.dataset.productId;
      const productTitle = card.dataset.productTitle;
      const productImage = card.dataset.productImage;

      const select = card.querySelector("select.bundle-variant-native");
      const selectedOption = select ? select.options[select.selectedIndex] : null;

      const variantId = selectedOption ? selectedOption.value : productId;
      const variantTitle = selectedOption ? selectedOption.textContent.trim() : "";
      const price = selectedOption ? Number(selectedOption.dataset.price) : 0;
      const comparePrice = selectedOption ? Number(selectedOption.dataset.comparePrice) : 0;
      const variantImage = (selectedOption && selectedOption.dataset.image) || productImage;

      const qtyInput = card.querySelector(".bundle-quantity");
      const qty = qtyInput ? Number(qtyInput.value) || 1 : 1;

      // Composite key ensures the same product in different variants stays separate.
      const key = productId + ":" + variantId;

      if (bundle[key]) {
        bundle[key].quantity += qty;
      } else {
        bundle[key] = { key, productId, variantId, title: productTitle, variantTitle, image: variantImage, price, comparePrice, quantity: qty };
      }

      renderCart();
      showError("");

      // Brief "Added" feedback on the button.
      const label = button.querySelector(".bundle-add-button__label");
      const originalText = label ? label.textContent : null;
      button.classList.add("is-added");
      window.clearTimeout(button._bundleResetTimeout);
      button._bundleResetTimeout = window.setTimeout(() => {
        button.classList.remove("is-added");
        if (label && originalText) label.textContent = originalText;
      }, 1200);

      // Mobile feedback: auto-open sheet or flash the bottom bar.
      if (window.innerWidth < 769) {
        const autoOpen = root.dataset.mobileAutoOpen === "true";
        const bar = document.getElementById("bundle-mobile-bar-" + sectionId);
        const toggle = document.getElementById("bundle-mobile-toggle-" + sectionId);
        const wrapper = root.querySelector(".bundle-set-creator__cart-wrapper");
        const overlay = document.getElementById("bundle-mobile-overlay-" + sectionId);

        if (autoOpen && wrapper && overlay && bar) {
          wrapper.classList.add("is-open");
          overlay.classList.add("is-open");
          bar.classList.add("is-sheet-open");
          document.body.style.overflow = "hidden";
        } else if (toggle) {
          toggle.classList.remove("is-flashing");
          void toggle.offsetWidth;
          toggle.classList.add("is-flashing");
          toggle.addEventListener("animationend", () => {
            toggle.classList.remove("is-flashing");
          }, { once: true });
        }
      }
    });
  });

  /* ===========================================================================
   * BUNDLE SIDEBAR CART (preview before adding to Shopify cart)
   * ========================================================================= */

  const cartListEl       = root.querySelector(".bundle-cart-product-list");
  const countEl          = root.querySelector(".cart-heading .count");
  const subtotalEl       = document.getElementById("bundle-cart-subtotal-value-" + sectionId);
  const discountValueEl  = document.getElementById("bundle-cart-sale-value-" + sectionId);
  const totalEl          = document.getElementById("bundle-cart-total-value-" + sectionId);
  const discountPercentEl = document.getElementById("discount-percentage-" + sectionId);
  const youSaveRow       = document.getElementById("you-save-row-" + sectionId);
  const youSaveEl        = document.getElementById("you-save-" + sectionId);
  const saleProductCountEl = document.getElementById("sale-product-count-" + sectionId);
  const salePercentageEl = document.getElementById("sale-percentage-" + sectionId);
  const saleInfoEl       = root.querySelector(".sale-info");
  const progressFillEl   = root.querySelector(".progress-fill");
  const progressPoint    = root.querySelector(".progress-point");
  const tierLabel1       = root.querySelector('[data-tier-label="1"]');
  const tierLabel2       = root.querySelector('[data-tier-label="2"]');
  const checkoutButton   = document.getElementById("bundle-add-all-" + sectionId);

  const BUNDLE_PRODUCT_VARIANT_ID = checkoutButton ? checkoutButton.dataset.bundleVariantId : null;

  // Tracks the last rendered total so the count-up animation has a start value.
  let displayedTotalCents = 0;

  /** Smoothly animates a money value from `start` to `end` cents. */
  function animateMoney(el, start, end, duration = 400) {
    const startTime = performance.now();

    function frame(now) {
      const progress = Math.min((now - startTime) / duration, 1);
      const current = Math.round(start + (end - start) * progress);
      el.textContent = formatMoney(current);
      if (progress < 1) requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);
  }

  function getTotalQuantity() {
    return Object.values(bundle).reduce((sum, item) => sum + item.quantity, 0);
  }

  function getSubtotalCents() {
    return Object.values(bundle).reduce((sum, item) => sum + item.price * item.quantity, 0);
  }

  /** Rebuilds the sidebar cart item list from current bundle state. */
  function renderCartItems() {
    if (!cartListEl) return;
    cartListEl.innerHTML = "";

    Object.keys(bundle).forEach((key) => {
      const item = bundle[key];

      const li = document.createElement("li");
      li.className = "bundle-cart-item";
      li.dataset.key = key;

      const img = document.createElement("img");
      img.src = item.image || "";
      img.alt = item.title;
      li.appendChild(img);

      const info = document.createElement("div");
      info.className = "bundle-cart-item__info";

      const titleP = document.createElement("p");
      titleP.className = "bundle-cart-item__title";
      titleP.textContent = item.title;
      info.appendChild(titleP);

      if (item.variantTitle && item.variantTitle !== "Default Title") {
        const variantP = document.createElement("p");
        variantP.className = "bundle-cart-item__variant";
        variantP.textContent = item.variantTitle;
        info.appendChild(variantP);
      }

      const priceP = document.createElement("p");
      priceP.className = "bundle-cart-item__price";
      priceP.textContent = formatMoney(item.price);
      info.appendChild(priceP);

      li.appendChild(info);

      // Inline quantity controls
      const qtyWrap = document.createElement("div");
      qtyWrap.className = "bundle-cart-item__qty";

      const minusBtn = document.createElement("button");
      minusBtn.type = "button";
      minusBtn.textContent = "−";

      const qtySpan = document.createElement("span");
      qtySpan.textContent = item.quantity;

      const plusBtn = document.createElement("button");
      plusBtn.type = "button";
      plusBtn.textContent = "+";

      minusBtn.addEventListener("click", () => {
        item.quantity--;
        if (item.quantity <= 0) delete bundle[key];
        renderCart();
      });

      plusBtn.addEventListener("click", () => {
        item.quantity++;
        renderCart();
      });

      qtyWrap.appendChild(minusBtn);
      qtyWrap.appendChild(qtySpan);
      qtyWrap.appendChild(plusBtn);
      li.appendChild(qtyWrap);

      const removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.className = "bundle-cart-item__remove";
      removeBtn.innerHTML = REMOVE_ICON_SVG;
      removeBtn.addEventListener("click", () => {
        delete bundle[key];
        renderCart();
      });
      li.appendChild(removeBtn);

      cartListEl.appendChild(li);
    });
  }

  /** Updates all totals, discount messaging, and the progress bar. */
  function renderTotals() {
    const totalQty = getTotalQuantity();
    const subtotalCents = getSubtotalCents();
    const activeTier = getActiveTier(totalQty);
    const nextTier = getNextTier(totalQty);
    const percent = activeTier ? activeTier.percent : 0;
    const discountCents = Math.round((subtotalCents * percent) / 100);
    const totalCents = subtotalCents - discountCents;

    if (countEl) countEl.textContent = totalQty;
    if (subtotalEl) subtotalEl.textContent = formatMoney(subtotalCents);
    if (discountValueEl) discountValueEl.textContent = formatMoney(discountCents);
    if (totalEl) {
      animateMoney(totalEl, displayedTotalCents, totalCents);
      displayedTotalCents = totalCents;
    }
    if (discountPercentEl) discountPercentEl.textContent = percent;

    // "You save" row
    if (youSaveRow && youSaveEl) {
      youSaveRow.hidden = discountCents <= 0;
      if (discountCents > 0) youSaveEl.textContent = formatMoney(discountCents);
    }

    // "Add X more to get Y% off" nudge
    if (saleInfoEl) {
      if (nextTier) {
        const remaining = nextTier.qty - totalQty;
        if (saleProductCountEl) saleProductCountEl.textContent = remaining;
        if (salePercentageEl) salePercentageEl.textContent = nextTier.percent;
        saleInfoEl.hidden = false;
      } else {
        saleInfoEl.hidden = true;
      }
    }

    // Progress bar — first tier maps to 50%, second tier to 100%.
    const firstTierQty = DISCOUNT_TIERS[0].qty;
    const secondTierQty = DISCOUNT_TIERS[1] ? DISCOUNT_TIERS[1].qty : firstTierQty;
    let progressPercent;

    if (totalQty <= 0) {
      progressPercent = 0;
    } else if (totalQty < firstTierQty) {
      progressPercent = (totalQty / firstTierQty) * 50;
    } else if (totalQty < secondTierQty) {
      progressPercent = 50 + ((totalQty - firstTierQty) / (secondTierQty - firstTierQty)) * 50;
    } else {
      progressPercent = 100;
    }

    if (progressFillEl) {
      progressFillEl.style.width = progressPercent + "%";
      progressFillEl.dataset.progress = String(progressPercent);
    }

    if (progressPoint) {
      progressPoint.style.left = progressPercent + "%";
      progressPoint.classList.toggle("reached", totalQty >= firstTierQty);
      if (progressPercent) {
        progressPoint.style.display = "flex";
        progressPoint.style.opacity = "1";
      }
    }

    if (tierLabel1) tierLabel1.classList.toggle("is-reached", totalQty >= firstTierQty);
    if (tierLabel2) tierLabel2.classList.toggle("is-reached", totalQty >= secondTierQty);
    if (checkoutButton) checkoutButton.disabled = totalQty < 2;
  }

  /** Re-renders the sidebar cart UI and persists state to localStorage. */
  function renderCart() {
    renderCartItems();
    renderTotals();
    saveBundleState();
  }

  /* ===========================================================================
   * CART DRAWER HELPERS
   *
   * After adding items to the Shopify cart, we bypass the theme's built-in
   * renderContents() method because it calls trapFocus() on DOM elements that
   * may not exist yet (specifically when the cart was previously empty).
   * Instead, we fetch fresh section HTML via the Section Rendering API and
   * inject it manually before opening the drawer.
   * ========================================================================= */

  /**
   * Replaces the cart drawer's inner HTML and header cart count bubble
   * with freshly rendered section HTML from Shopify.
   */
  function refreshDrawerAndBubble(sections) {
    const cartDrawer = document.querySelector("cart-drawer");
    if (!cartDrawer || !sections["cart-drawer"]) return;

    const parser = new DOMParser();
    const doc = parser.parseFromString(sections["cart-drawer"], "text/html");
    const newContent = doc.querySelector(".drawer__inner");
    const currentContent = cartDrawer.querySelector(".drawer__inner");
    if (newContent && currentContent) {
      currentContent.innerHTML = newContent.innerHTML;
    }

    // Update the header cart icon bubble count. When the cart was previously
    // empty, the .cart-count-bubble element doesn't exist in the DOM yet,
    // so we create it and append it to #cart-icon-bubble.
    if (sections["cart-icon-bubble"]) {
      const bubbleDoc = parser.parseFromString(sections["cart-icon-bubble"], "text/html");
      const newBubble = bubbleDoc.querySelector(".cart-count-bubble");
      const currentIconBubble = document.getElementById("cart-icon-bubble");

      if (currentIconBubble) {
        const existingBubble = currentIconBubble.querySelector(".cart-count-bubble");
        if (existingBubble && newBubble) {
          existingBubble.innerHTML = newBubble.innerHTML;
        } else if (!existingBubble && newBubble) {
          currentIconBubble.appendChild(newBubble);
        }
      }
    }
  }

  /**
   * Manually opens the cart drawer and wires up close handlers.
   * Used instead of the theme's native open method to avoid the trapFocus
   * crash on empty-cart-to-filled transitions.
   */
  function openCartDrawer(cartDrawer) {
    cartDrawer.classList.remove("is-empty");

    const openDetail = cartDrawer.querySelector("details");
    if (openDetail) openDetail.setAttribute("open", "");

    cartDrawer.classList.add("animate", "active");
    document.body.classList.add("overflow-hidden");

    const closeDrawer = () => {
      if (openDetail) openDetail.removeAttribute("open");
      cartDrawer.classList.remove("active");
      document.body.classList.remove("overflow-hidden");
    };

    const overlay = cartDrawer.querySelector(".cart-drawer__overlay");
    if (overlay) overlay.addEventListener("click", closeDrawer, { once: true });

    const closeBtn = cartDrawer.querySelector("button.drawer__close");
    if (closeBtn) closeBtn.addEventListener("click", closeDrawer, { once: true });
  }

  /* ===========================================================================
   * ADD BUNDLE TO SHOPIFY CART
   *
   * Builds the line items array and sends it to /cart/add.js. Each bundle
   * consists of:
   *   1. A parent line item (the $0 "Custom Bundle" placeholder product)
   *   2. One child line item per selected product/variant
   *
   * All items share a unique _bundle_id property so they can be grouped in
   * the cart drawer (via Liquid) and removed together.
   *
   * Properties prefixed with "_" are hidden from the customer in Shopify's
   * default cart UI but remain accessible in Liquid via item.properties.
   * ========================================================================= */
  if (checkoutButton && BUNDLE_PRODUCT_VARIANT_ID) {
    checkoutButton.addEventListener("click", () => {
      const keys = Object.keys(bundle);
      if (keys.length === 0) return;

      const totalQty = getTotalQuantity();
      if (totalQty < 2) {
        showError("Add at least 2 products to create a bundle.");
        return;
      }

      const activeTier = getActiveTier(totalQty);
      const discountPercent = activeTier ? activeTier.percent : 0;
      const bundleId = "bundle_" + Date.now();

      const items = [];

      // Parent: $0 placeholder that identifies the bundle in cart/checkout.
      items.push({
        id: parseInt(BUNDLE_PRODUCT_VARIANT_ID, 10),
        quantity: 1,
        properties: {
          _bundle_id: bundleId,
          _bundle_name: "{{ section.settings.bundle.title }}",
          _bundle_parent: "true",
          _bundle_discount: discountPercent > 0 ? discountPercent + "%" : "0%"
        }
      });

      // Children: the actual products the customer selected.
      keys.forEach((key) => {
        const item = bundle[key];
        const parsedVariantId = parseInt(item.variantId, 10);
        if (!isNaN(parsedVariantId) && item.quantity > 0) {
          items.push({
            id: parsedVariantId,
            quantity: item.quantity,
            properties: {
              _bundle_id: bundleId,
              _bundle_name: "{{ section.settings.bundle.title }}",
              _bundle_child: "true",
              _bundle_discount: discountPercent > 0 ? discountPercent + "%" : "0%"
            }
          });
        }
      });

      const labelEl = checkoutButton.querySelector(".bundle-checkout-button__label");
      const originalLabel = labelEl ? labelEl.textContent : "Add bundle to Cart";

      checkoutButton.disabled = true;
      if (labelEl) labelEl.textContent = "Adding...";
      showError("");

      fetch(ROOT_URL + "cart/add.js", {
        method: "POST",
        headers: { "Content-Type": "application/json", "Accept": "application/json" },
        body: JSON.stringify({ items: items })
      })
        .then((response) => {
          return response.json().then((data) => {
            if (!response.ok) {
              const message = (data && data.description) || (data && data.message) || "Something went wrong.";
              throw new Error(message);
            }
            return data;
          });
        })
        // Fetch freshly rendered cart-drawer and cart-icon-bubble sections.
        .then(() => {
          if (labelEl) labelEl.textContent = "Added!";
          return fetch(ROOT_URL + "?sections=cart-drawer,cart-icon-bubble");
        })
        .then((r) => r.json())
        .then((sections) => {
          const cartDrawer = document.querySelector("cart-drawer");
          if (cartDrawer && sections["cart-drawer"]) {
            refreshDrawerAndBubble(sections);
            openCartDrawer(cartDrawer);
          } else {
            // Fallback for themes without a cart-drawer component.
            const cartButton = document.querySelector(".header__icon--cart") || document.querySelector("[data-cart-drawer-trigger]");
            if (cartButton) cartButton.click();
          }
        })
        .then(() => {
          // Reset the bundle builder UI and clear persisted state.
          bundle = {};
          clearBundleState();
          renderCart();

          // Restore button label after a brief "Added!" confirmation.
          window.setTimeout(() => {
            if (labelEl) labelEl.textContent = originalLabel;
            checkoutButton.disabled = getTotalQuantity() < 2;
          }, 1500);
        })
        .catch((error) => {
          showError(error.message || "Something went wrong adding this bundle to your cart.");
          if (labelEl) labelEl.textContent = originalLabel;
          checkoutButton.disabled = false;
        });
    });
  }

  // Render the sidebar cart on page load, restoring any previously saved bundle.
  renderCart();

  /* ===========================================================================
   * MOBILE GRID TOGGLE
   *
   * Switches the product grid between 1 and 2 columns on mobile.
   * Hidden on desktop where the grid uses auto-fill.
   * ========================================================================= */
  const gridToggleWrap = document.getElementById("bundle-grid-toggle-" + sectionId);
  const productList = root.querySelector(".bundle__product-list");

  if (gridToggleWrap && productList) {
    productList.classList.add("grid-cols-2");

    gridToggleWrap.querySelectorAll(".bundle-grid-toggle__btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        gridToggleWrap.querySelectorAll(".bundle-grid-toggle__btn").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        const cols = btn.dataset.columns;
        productList.classList.remove("grid-cols-1", "grid-cols-2");
        productList.classList.add("grid-cols-" + cols);
      });
    });
  }

  /* ===========================================================================
   * MOBILE BOTTOM SHEET
   *
   * On screens below 769px, the sidebar cart becomes a bottom sheet that
   * slides up from the bottom of the viewport. A fixed toggle bar appears
   * at the bottom when the bundle section is in view (via IntersectionObserver)
   * showing the current item count. Tapping it opens the sheet; tapping
   * the overlay or the bar again closes it.
   * ========================================================================= */
  const mobileBar = document.getElementById("bundle-mobile-bar-" + sectionId);
  const mobileToggle = document.getElementById("bundle-mobile-toggle-" + sectionId);
  const mobileOverlay = document.getElementById("bundle-mobile-overlay-" + sectionId);
  const cartWrapper = root.querySelector(".bundle-set-creator__cart-wrapper");
  const mobileBarCount = mobileBar ? mobileBar.querySelector(".bundle-mobile-bar__count") : null;

  /** Keeps the mobile bar's item count in sync with the bundle state. */
  function updateMobileBarCount() {
    if (mobileBarCount) mobileBarCount.textContent = getTotalQuantity();
  }

  // Patch renderCart to also update the mobile bar count.
  const originalRenderCart = renderCart;
  renderCart = function () {
    originalRenderCart();
    updateMobileBarCount();
  };

  if (mobileToggle && cartWrapper && mobileOverlay) {
    const isMobile = () => window.innerWidth < 769;

    const openSheet = () => {
      if (!isMobile()) return;
      cartWrapper.classList.add("is-open");
      mobileOverlay.classList.add("is-open");
      mobileBar.classList.add("is-sheet-open");
      document.body.style.overflow = "hidden";
    };

    const closeSheet = () => {
      cartWrapper.classList.remove("is-open");
      mobileOverlay.classList.remove("is-open");
      mobileBar.classList.remove("is-sheet-open");
      document.body.style.overflow = "";
    };

    mobileToggle.addEventListener("click", () => {
      if (cartWrapper.classList.contains("is-open")) {
        closeSheet();
      } else {
        openSheet();
      }
    });

    mobileOverlay.addEventListener("click", closeSheet);

    // Drag handle: tap to close, or drag down to dismiss the sheet.
    const sheetHandle = document.getElementById("bundle-sheet-handle-" + sectionId);
    if (sheetHandle) {
      // Tap the handle to close.
      sheetHandle.addEventListener("click", closeSheet);

      // Drag down to close — tracks touch movement and closes if dragged
      // more than 60px downward. Otherwise snaps the sheet back open.
      let startY = 0;
      let currentY = 0;
      let isDragging = false;

      sheetHandle.addEventListener("touchstart", (e) => {
        if (!cartWrapper.classList.contains("is-open")) return;
        startY = e.touches[0].clientY;
        currentY = startY;
        isDragging = true;
        cartWrapper.style.transition = "none";
      }, { passive: true });

      sheetHandle.addEventListener("touchmove", (e) => {
        if (!isDragging) return;
        currentY = e.touches[0].clientY;
        const diff = currentY - startY;
        // Only allow dragging downward.
        if (diff > 0) {
          cartWrapper.style.transform = "translateY(" + diff + "px)";
        }
      }, { passive: true });

      sheetHandle.addEventListener("touchend", () => {
        if (!isDragging) return;
        isDragging = false;
        cartWrapper.style.transition = "";
        const diff = currentY - startY;
        if (diff > 60) {
          closeSheet();
        }
        // Reset inline transform — CSS class handles the position.
        cartWrapper.style.transform = "";
      });
    }

    // Show the fixed bottom bar only when the bundle section is in the viewport.
    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              mobileBar.classList.add("is-visible");
            } else {
              mobileBar.classList.remove("is-visible");
              closeSheet();
            }
          });
        },
        { threshold: 0 }
      );
      observer.observe(root);
    }

    // Close sheet on resize to desktop.
    window.addEventListener("resize", () => {
      if (!isMobile()) closeSheet();
    });
  }

  // Run once more to set the initial mobile bar count.
  updateMobileBarCount();
});
