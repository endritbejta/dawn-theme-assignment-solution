    </div>
      <div class="bundle-set-creator__product-list-wrapper">
        <ul class="bundle__product-list">

          {% for product in section.settings.product_list %}

            {% if product.available %}

              <li
                class="bundle-product"
                data-product-id="{{ product.id }}"
                data-product-handle="{{ product.handle }}"
                data-product-title="{{ product.title | escape }}"
                data-product-image="{{ product.selected_or_first_available_variant.featured_image | default: product.featured_media | image_url: width: 200 }}"
                data-tags="{{ product.tags | join: ',' | handleize }}">
                <a href="{{ product.url }}" class="bundle-product__media">
                  <div class="bundle-product__loader"></div>
                  <img
                    class="bundle-product__image"
                    src="{{ product.selected_or_first_available_variant.featured_image | default: product.featured_media | image_url: width: 500 }}"
                    alt="{{ product.selected_or_first_available_variant.featured_image.alt | default: product.featured_media.alt | escape }}"
                    width="300"
                    height="300"
                    loading="lazy">
                </a>

                <div class="bundle-product__information-wrapper">

                  <div class="bundle-product__information">
                    <h3>{{ product.title }}</h3>

                    <div class="price-holder">
                      {% if product.compare_at_price > product.price %}
                        <span class="price price--sale">
                          {{ product.price | money }}
                        </span>

                        <s class="price price--compare">
                          {{ product.compare_at_price | money }}
                        </s>
                      {% else %}
                        <span class="price">
                          {{ product.price | money }}
                        </span>
                      {% endif %}
                    </div>
                  </div>

                  <div
                    class="bundle__dropdown"
                    {% if product.variants.size <= 1 %}
                    hidden{% endif %}>

                    <select
                      class="bundle-variant-native visually-hidden"
                      name="id"
                      id="variant-{{ product.id }}">
                      {% for variant in product.variants %}
                        <option
                          value="{{ variant.id }}"
                          data-price="{{ variant.price }}"
                          data-compare-price="{{ variant.compare_at_price | default: 0 }}"
                          data-available="{{ variant.available }}"
                          data-image="{{ variant.featured_image | default: product.featured_media | image_url: width: 200 }}"
                          data-image-large="{{ variant.featured_image | default: product.featured_media | image_url: width: 500 }}"
                          data-inventory="{{ variant.inventory_quantity | default: 0 }}"
                          {% if variant == product.selected_or_first_available_variant %}
                          selected
                          {% endif %}
                          {% unless variant.available %}
                          disabled
                          {% endunless %}>
                          {{ variant.title }}
                        </option>
                      {% endfor %}
                    </select>

                    <button
                      type="button"
                      class="bundle-dropdown-toggle"
                      aria-expanded="false">
                      <span id="bundle-dropdown-text">{{ product.selected_or_first_available_variant.title }}</span>
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg">
                        <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                        <g
                          id="SVGRepo_tracerCarrier"
                          stroke-linecap="round"
                          stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
                        <g id="Arrow / Caret_Down_SM">
                          <path
                            id="Vector"
                            d="M15 11L12 14L9 11"
                            stroke="#000000"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                        </g>
                      </g>
                    </svg>
                  </button>

                  <ul class="bundle-dropdown-options" hidden>
                    {% for variant in product.variants %}
                      <li>
                        <button
                          type="button"
                          class="bundle-option"
                          data-variant-id="{{ variant.id }}"
                          data-variant-title="{{ variant.title }}"
                          data-price="{{ variant.price }}"
                          data-compare-price="{{ variant.compare_at_price | default: 0 }}"
                          data-image="{{ variant.featured_image | default: product.featured_media | image_url: width: 200 }}"
                          data-image-large="{{ variant.featured_image | default: product.featured_media | image_url: width: 500 }}"
                          data-inventory="{{ variant.inventory_quantity | default: 0 }}"
                          {% unless variant.available %}
                          disabled
                          {% endunless %}>
                          {{ variant.title }}

                          {% unless variant.available %}
                            — Sold out
                          {% endunless %}
                        </button>
                      </li>
                    {% endfor %}
                  </ul>

                </div>

                <div class="bundle__quantity-selector">
                  <button
                    type="button"
                    class="quantity-btn"
                    data-action="decrease"
                    aria-label="Decrease quantity">
                    −
                  </button>

                  <input
                    id="qty-{{ product.id }}"
                    type="number"
                    min="1"
                    max="{{ product.selected_or_first_available_variant.inventory_quantity }}"
                    value="1"
                    class="bundle-quantity">

                  <button
                    type="button"
                    class="quantity-btn"
                    data-action="increase"
                    aria-label="Increase quantity">
                    +
                  </button>
                </div>

                <button
                  type="button"
                  class="bundle-add-button"
                  data-product-id="{{ product.id }}">
                  <span class="bundle-add-button__label">⊕ Add to Bundle</span>
                </button>
              </div>
            </li>
          {% endif %}
        {% endfor %}

        {%- if section.settings.product_list == blank and request.design_mode -%}
          {%- for i in (1..6) -%}
            <li class="bundle-product bundle-product--placeholder">
              <div class="bundle-product__media">
                <div class="bundle-product__placeholder-image">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
                    <path d="M2.75 6A3.25 3.25 0 016 2.75h12A3.25 3.25 0 0121.25 6v12A3.25 3.25 0 0118 21.25H6A3.25 3.25 0 012.75 18V6z" stroke="#bbb" stroke-width="1.5"/>
                    <circle cx="16" cy="8" r="1.5" stroke="#bbb" stroke-width="1.5"/>
                    <path d="M2.75 14.5l3.22-2.76a2 2 0 012.56 0L12 14.5l2.97-2.54a2 2 0 012.56 0l3.72 3.19" stroke="#bbb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
              <div class="bundle-product__information-wrapper">
                <div class="bundle-product__information">
                  <h3>Product name</h3>
                  <div class="price-holder">
                    <span class="price" style="color: #aaa;">€0,00</span>
                  </div>
                </div>
                <div class="bundle__quantity-selector">
                  <button type="button" class="quantity-btn" disabled>−</button>
                  <input type="number" value="1" class="bundle-quantity" disabled>
                  <button type="button" class="quantity-btn" disabled>+</button>
                </div>
                <button type="button" class="bundle-add-button" disabled>
                  <span class="bundle-add-button__label">⊕ Add to Bundle</span>
                </button>
              </div>
            </li>
          {%- endfor -%}
        {%- endif -%}

      </ul>

      <p
        class="bundle-no-results"
        hidden
        style="margin-top: 12px; color: #777;">No products match this filter.</p>
    </div>

    {%- comment -%} Mobile bottom sheet toggle bar {%- endcomment -%}
    <div class="bundle-mobile-bar" id="bundle-mobile-bar-{{ section.id }}">
      <button
        type="button"
