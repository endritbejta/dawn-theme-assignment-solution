<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Use capturing phase to intercept clicks before Dawn's cart.js
    // handles them. Dawn listens on the cart form and may prevent
    // default or stop propagation for clicks inside the table.
    document.addEventListener("click", (e) => {
      const header = e.target.closest(".bundle-group__header");
      if (header && header.closest("#main-cart-items")) {
        e.preventDefault();
        e.stopPropagation();
        const group = header.closest(".bundle-group");
        const children = group.querySelector(".bundle-group__children");
        const toggle = group.querySelector(".bundle-group__toggle");
        const isOpen = children.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", String(isOpen));
      }

      const removeBtn = e.target.closest(".bundle-group__remove");
      if (removeBtn && removeBtn.closest("#main-cart-items")) {
        e.preventDefault();
        e.stopPropagation();
        const bundleId = removeBtn.dataset.bundleId;
        const rootUrl = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || "/";
        const group = removeBtn.closest(".bundle-group");
        const loadingSpinner = group ? group.querySelector(".loading__spinner") : null;

        if (group) group.classList.add("is-removing");
        if (loadingSpinner) loadingSpinner.classList.remove("hidden");

        fetch(rootUrl + "cart.js")
          .then((r) => r.json())
          .then((cart) => {
            const updates = {};
            cart.items.forEach((item) => {
              if (item.properties && item.properties._bundle_id === bundleId) {
                updates[item.key] = 0;
              }
            });
            return fetch(rootUrl + "cart/update.js", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ updates: updates })
            });
          })
          .then(() => {
            window.location.reload();
          });
      }
    }, true);
  });
</script>

